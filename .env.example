# =============================================================================
# AgentFence Configuration
# =============================================================================
# Copy this file to .env and customize.
# All values shown are defaults — remove any you don't need to change.
# =============================================================================

# ------------------------------------------------------------------------------
# AI Provider
# ------------------------------------------------------------------------------
# Your API key. If empty, mock mode is activated automatically.
AF_API_KEY=

# Provider base URL (OpenRouter, OpenAI, or local)
AF_PROVIDER_URL=https://openrouter.ai/api/v1

# Default model for cost estimation
AF_PROVIDER_MODEL_DEFAULT=gpt-4o

# Default max output tokens for estimation
AF_PROVIDER_MAX_OUTPUT_TOKENS_DEFAULT=500

# Request timeout in seconds for outbound provider calls
AF_GATEWAY_REQUEST_TIMEOUT=120

# ------------------------------------------------------------------------------
# Gateway
# ------------------------------------------------------------------------------
AF_GATEWAY_HOST=0.0.0.0
AF_GATEWAY_PORT=8000
AF_GATEWAY_WORKERS=1

# Rate limiting (per-agent)
AF_GATEWAY_RATE_LIMIT_ENABLED=false
AF_GATEWAY_RATE_LIMIT_RPM=60

# Max request body size in bytes (10 MB)
AF_GATEWAY_MAX_REQUEST_BODY_SIZE=10485760

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
AF_DB_URL=sqlite:///agentfence.db
AF_DB_POOL_SIZE=5
AF_DB_RETRY_MAX_ATTEMPTS=3

# ------------------------------------------------------------------------------
# Budget & Cost Control
# ------------------------------------------------------------------------------
# Default budget in USD for new tasks
AF_BUDGET_DEFAULT_USD=1.0

# Path to pricing JSON file
AF_BUDGET_PRICING_PATH=pricing.json

# Pricing cache TTL in seconds
AF_BUDGET_PRICING_CACHE_TTL_SEC=300

# Circuit breaker threshold (remaining budget that triggers it)
AF_BUDGET_CIRCUIT_BREAKER_THRESHOLD=0.0

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
AF_LOG_LEVEL=INFO
AF_LOG_FORMAT=readable
# AF_LOG_FILE=agentfence.log

# ------------------------------------------------------------------------------
# Tracing
# ------------------------------------------------------------------------------
AF_TRACE_DIR=traces
AF_TRACE_BATCH_SIZE=1
AF_TRACE_FLUSH_INTERVAL_SEC=5.0
AF_TRACE_MAX_FILE_SIZE_MB=100

# ------------------------------------------------------------------------------
# Global Flags
# ------------------------------------------------------------------------------
# Force mock mode (no real API calls)
AF_MOCK_MODE=true

# Debug mode (verbose output)
AF_DEBUG=false
